{
  "name": "@clipify/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "clipify": "src/index.ts"
  },
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "build:binary": "bun build src/index.ts --compile --outfile dist/clipify",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit"
  },
  "dependencies": {
    "@clipify/api-client": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.9.2"
  }
}
