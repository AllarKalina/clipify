{
  "name": "@clipify/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "clipify": "src/index.ts"
  },
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "dev:hot": "bun --hot src/index.ts",
    "start": "bun src/index.ts",
    "build:binary": "bun build src/index.ts --compile --outfile dist/clipify",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit"
  },
  "dependencies": {
    "@clipify/api-client": "workspace:*",
    "ink": "^6.7.0",
    "react": "^19.2.4",
    "react-devtools-core": "^7.0.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "typescript": "^5.9.2"
  }
}
