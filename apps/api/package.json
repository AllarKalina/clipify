{
  "name": "@clipify/api",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/server.ts",
    "start": "bun src/server.ts",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config drizzle.config.ts"
  },
  "dependencies": {
    "@clipify/contracts": "workspace:*",
    "@elysiajs/openapi": "^1.4.8",
    "@elysiajs/opentelemetry": "^1.2.0",
    "better-auth": "^1.3.13",
    "drizzle-orm": "^0.44.5",
    "elysia": "^1.4.16",
    "postgres": "^3.4.7",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.4",
    "typescript": "^5.9.2"
  }
}
