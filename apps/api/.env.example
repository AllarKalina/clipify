NODE_ENV=development
APP_NAME=clipify-api
API_VERSION=v1
MIN_CLI_VERSION=0.1.0
LATEST_CLI_VERSION=0.1.0
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info

DATABASE_URL=postgres://postgres:postgres@localhost:5432/bun_template

BETTER_AUTH_SECRET=replace-with-at-least-16-characters
BETTER_AUTH_URL=http://localhost:3000

SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/v1/cli/auth/callback/public
SPOTIFY_TOKEN_ENCRYPTION_KEY=
RATE_LIMIT_TRUST_PROXY_HEADERS=false

OTEL_ENABLED=true
OTEL_SERVICE_NAME=clipify-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
OTEL_EXPORTER_OTLP_HEADERS=
